# Required: server-side Gemini API key.
# Get a key from Google AI Studio or the Gemini API console.
# Never commit your real .env file.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Optional model overrides. Leave these unset to use the defaults in server.ts.
GEMINI_TEXT_MODEL="gemini-3.5-flash"
GEMINI_IMAGE_MODEL="gemini-3-pro-image"
GEMINI_VIDEO_MODEL="veo-3.1-lite-generate-preview"

# Optional: public app URL for hosted environments that need self-referential links.
APP_URL="http://localhost:3000"
